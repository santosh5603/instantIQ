# Application
APP_ENV=development
APP_SECRET_KEY=change_me_64_char_random_string_for_production_env
API_PORT=8000

# Database (Supabase PostgreSQL Connection String)
# Example: postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
DATABASE_POOL_SIZE=5

# Redis URL (Self-hosted or managed)
REDIS_URL=redis://localhost:6379/0

# Supabase Storage Configuration
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxx
SUPABASE_SERVICE_KEY=eyJxxxx
SUPABASE_STORAGE_BUCKET=reelise-resources

# Instagram Collector Account
INSTAGRAM_USERNAME=your_collector_username
INSTAGRAM_PASSWORD=your_collector_password
INSTAGRAM_SESSION_PATH=session/instagram_session.json

# Notion API Configuration
NOTION_API_KEY=secret_xxxx
NOTION_RESOURCES_DB_ID=xxxx

# Human-like Automation Worker Constraints
MAX_DAILY_FOLLOWS=10
FOLLOW_COOLDOWN_SECONDS=300
COMMENT_DELAY_MIN=10
COMMENT_DELAY_MAX=30
DM_POLL_INTERVAL_MIN=45
DM_POLL_INTERVAL_MAX=90
DM_MAX_WAIT_MINUTES=30
